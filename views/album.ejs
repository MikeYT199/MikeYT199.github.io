<%- include('partials/header') %>

<section class="album-detail-section">
  <div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
      <ol class="breadcrumb custom-breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/#albums">Álbumes</a></li>
        <li class="breadcrumb-item active"><%= album.titulo %></li>
      </ol>
    </nav>

    <!-- Header del álbum -->
    <div class="album-detail-header mb-5">
      <div class="row align-items-end">
        <div class="col-lg-8">
          <span class="section-tag">Álbum</span>
          <h1 class="album-detail-titulo"><%= album.titulo %></h1>
          <p class="album-detail-desc"><%= album.descripcion %></p>
          <div class="album-detail-meta">
            <span><i class="bi bi-images me-1"></i><%= album.fotos.length %> fotos</span>
            <span>
              <button class="like-btn like-btn-lg" data-tipo="album" data-id="<%= album.id %>" data-liked="false">
                <i class="bi bi-heart like-icon me-1"></i>
                <span class="like-count"><%= album.likes %></span> Me gusta
              </button>
            </span>
            <span>
              <button class="fav-btn" data-tipo="album" data-id="<%= album.id %>"
                data-titulo="<%= album.titulo %>"
                data-url="<%= album.portada %>"
                data-album="<%= album.titulo %>">
                <i class="bi bi-bookmark fav-icon me-1"></i>Guardar
              </button>
            </span>
          </div>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
          <a href="/#albums" class="btn btn-outline-custom">
            <i class="bi bi-arrow-left me-2"></i>Volver a Álbumes
          </a>
        </div>
      </div>
    </div>

    <!-- Grid de fotos -->
    <div class="row g-3">
      <% album.fotos.forEach(function(foto, index) { %>
      <div class="col-sm-6 col-lg-4">
        <div class="foto-card" data-bs-toggle="modal" data-bs-target="#fotoModal"
          data-foto-url="<%= foto.url %>" data-foto-titulo="<%= foto.titulo %>">
          <img src="<%= foto.url %>" alt="<%= foto.titulo %>" loading="lazy" class="foto-card-img">
          <div class="foto-card-overlay">
            <h4 class="foto-card-titulo"><%= foto.titulo %></h4>
            <div class="d-flex gap-2 justify-content-center">
              <button class="like-btn like-btn-sm"
                data-tipo="foto" data-id="<%= foto.id %>" data-liked="false"
                onclick="event.stopPropagation()">
                <i class="bi bi-heart like-icon"></i>
                <span class="like-count"><%= foto.likes %></span>
              </button>
              <button class="fav-btn fav-btn-sm"
                data-tipo="foto" data-id="<%= foto.id %>"
                data-titulo="<%= foto.titulo %>"
                data-url="<%= foto.url %>"
                data-album="<%= album.titulo %>"
                onclick="event.stopPropagation()">
                <i class="bi bi-bookmark fav-icon"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- Modal foto -->
<div class="modal fade" id="fotoModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content foto-modal-content">
      <button type="button" class="modal-close-btn" data-bs-dismiss="modal">
        <i class="bi bi-x-lg"></i>
      </button>
      <img src="" alt="" id="modalFotoImg" class="modal-foto-img">
      <div class="modal-foto-caption" id="modalFotoTitulo"></div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999">
  <div id="notifToast" class="toast align-items-center" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastMessage">Acción realizada</div>
      <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>
// Modal foto
document.querySelectorAll('.foto-card').forEach(card => {
  card.addEventListener('click', function() {
    document.getElementById('modalFotoImg').src = this.dataset.fotoUrl;
    document.getElementById('modalFotoTitulo').textContent = this.dataset.fotoTitulo;
  });
});
</script>

<%- include('partials/footer') %>
